# Telefon farkli bir sunucuya baglanacaksa:
# VITE_SYNC_URL=http://192.168.1.20:8787

# Discord Developer Portal uygulama kimligi (yalnizca masaustu kabugu okur):
# RITIM_DISCORD_CLIENT_ID=123456789012345678

# Google bilgileri uygulamadaki kurulum ekranindan girilebilir. İsterseniz
# gelistirme ortaminda ana surece ortam degiskeni olarak da verebilirsiniz:
# RITIM_GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
# RITIM_GOOGLE_CLIENT_SECRET=GOCSPX-...
